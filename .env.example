# 실제 배포/실행 시 .env 파일로 복사한 뒤 값을 채우세요. (.env 는 git에 커밋되지 않습니다)
# python -c "import secrets; print(secrets.token_hex(32))" 로 안전한 키를 생성하세요.

# 세션/CSRF 서명에 사용되는 비밀 키. 반드시 무작위 값으로 설정할 것.
SECRET_KEY=change-me-to-a-random-64-char-hex-string

# 실행 환경: development | production
FLASK_ENV=development

# HTTPS 로 서비스할 때만 True 로 설정 (쿠키 Secure 플래그)
SESSION_COOKIE_SECURE=False

# 계좌번호 암호화 키 (hex 64자 = 32바이트). 미설정 시 SECRET_KEY 에서 파생됩니다.
# 운영에서는 SECRET_KEY 와 분리된 별도 키 사용을 권장합니다.
# python -c "import secrets; print(secrets.token_hex(32))"
ACCOUNT_ENC_KEY=

# 최초 실행 시 생성할 관리자 계정
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-admin-password
